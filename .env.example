# ============================================
# Server (backend only - never prefix with REACT_APP_)
# ============================================

# OpenAI API key - get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model (optional, defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Allowed CORS origin for production (e.g. https://yani-mohellebi.vercel.app)
# Only needed for the Express dev server, not for Vercel serverless
# CLIENT_ORIGIN=https://your-domain.com

# Server port (optional, defaults to 5001)
# PORT=5001
